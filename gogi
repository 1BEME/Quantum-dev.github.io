<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quantum Dev</title>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #030508;
  --accent: #00d4ff;
  --accent2: #00ffcc;
  --text: #f0f4f8;
  --muted: #6b7a8d;
}

body {
  margin: 0;
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
}

/* NAV */
nav {
  position: fixed;
  top: 0;
  width: 100%;
  padding: 20px 60px;
  display: flex;
  justify-content: space-between;
  transition: 0.4s;
  z-index: 100;
}

nav.scrolled {
  background: rgba(3,5,8,0.9);
  backdrop-filter: blur(12px);
  padding: 14px 60px;
}

.logo {
  font-family: 'Syne';
  font-weight: 800;
}

nav a {
  color: var(--muted);
  margin-left: 20px;
  text-decoration: none;
  font-size: 14px;
  transition: 0.3s;
}

nav a:hover {
  color: var(--text);
}

/* PAGE SYSTEM */
.page {
  display: none;
  padding: 120px 60px 80px;
  opacity: 0;
  transform: translateY(40px);
}

.page.active {
  display: block;
  animation: pageEnter 0.8s ease forwards;
}

@keyframes pageEnter {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* HERO BG */
.orb {
  position: absolute;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  filter: blur(120px);
  background: radial-gradient(circle, rgba(0,212,255,0.15), transparent);
  animation: float 8s ease-in-out infinite;
}

.orb2 {
  background: radial-gradient(circle, rgba(0,255,204,0.1), transparent);
  left: 10%;
  top: 40%;
  animation-direction: reverse;
}

@keyframes float {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-40px); }
}

/* TEXT */
h1 {
  font-family: 'Syne';
  font-size: 56px;
  margin-bottom: 20px;
}

p {
  max-width: 600px;
  color: var(--muted);
}

/* BUTTON */
.btn {
  display: inline-block;
  margin-top: 20px;
  padding: 14px 28px;
  border: 1px solid var(--accent);
  color: var(--accent);
  text-decoration: none;
  transition: 0.3s;
  position: relative;
  overflow: hidden;
}

.btn:hover {
  background: var(--accent);
  color: black;
  box-shadow: 0 10px 40px rgba(0,212,255,0.4);
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 20px;
  margin-top: 40px;
}

.card {
  border: 1px solid rgba(255,255,255,0.05);
  padding: 30px;
  transition: 0.4s;
  transform: translateY(30px);
  opacity: 0;
}

.card.visible {
  transform: translateY(0);
  opacity: 1;
}

.card:hover {
  border-color: var(--accent);
  background: rgba(0,212,255,0.03);
}

/* CONTACT */
footer {
  padding: 40px 60px;
  border-top: 1px solid rgba(255,255,255,0.05);
}

/* SCROLL ANIM */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: 0.8s;
}

.reveal.active {
  opacity: 1;
  transform: translateY(0);
}
</style>
</head>

<body>

<nav id="nav">
  <div class="logo">Quantum Dev</div>
  <div>
    <a href="#" onclick="showPage('home')">Home</a>
    <a href="#" onclick="showPage('about')">About</a>
    <a href="#" onclick="showPage('services')">Services</a>
    <a href="#" onclick="showPage('contact')">Contact</a>
  </div>
</nav>

<!-- HOME -->
<div id="home" class="page active">
  <div class="orb"></div>
  <div class="orb orb2"></div>

  <h1 class="reveal">We Build Websites That Convert</h1>
  <p class="reveal">Modern, fast, high-converting websites and apps for serious businesses.</p>
  <a class="btn reveal" onclick="showPage('contact')">Start a Project</a>
</div>

<!-- ABOUT -->
<div id="about" class="page">
  <h1 class="reveal">About</h1>
  <p class="reveal">
    Quantum Dev builds premium digital experiences focused on performance, design, and results.
  </p>
</div>

<!-- SERVICES -->
<div id="services" class="page">
  <h1 class="reveal">Services</h1>

  <div class="grid">
    <div class="card">Website Design</div>
    <div class="card">Web Apps</div>
    <div class="card">Website Upgrades</div>
    <div class="card">UI/UX Design</div>
  </div>
</div>

<!-- CONTACT -->
<div id="contact" class="page">
  <h1 class="reveal">Contact</h1>

  <p>Email: quantumtech.ioe@gmail.com</p>
  <p>WhatsApp: +27 69 333 5402</p>

  <a class="btn" href="mailto:quantumtech.ioe@gmail.com">Send Email</a>
  <a class="btn" href="https://wa.me/27693335402">WhatsApp</a>
</div>

<footer>
  <p>© Quantum Dev</p>
</footer>

<script>
// PAGE SWITCH
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

// NAV SCROLL EFFECT
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 20);
});

// SCROLL REVEAL
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('active');
    }
  });
});

document.querySelectorAll('.reveal, .card').forEach(el => {
  observer.observe(el);
});
</script>

</body>
</html>